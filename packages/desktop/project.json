{
	"name": "desktop",
	"projectType": "application",
	"root": "packages/desktop",
	"sourceRoot": "packages/desktop/src",
	"implicitDependencies": ["contracts"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/desktop && bun run build",
				"forwardAllArgs": true
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/desktop && bun run dev",
				"forwardAllArgs": true
			}
		},
		"check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/desktop && bun run check",
				"forwardAllArgs": true
			}
		},
		"package": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/desktop && bun run package",
				"forwardAllArgs": true
			}
		}
	}
}
