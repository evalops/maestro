{
	"$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
	"appId": "com.evalops.composer",
	"productName": "Composer",
	"artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
	"directories": {
		"output": "release",
		"buildResources": "assets"
	},
	"electronVersion": "33.2.1",
	"files": ["dist/**/*", "dist-electron/**/*"],
	"asar": true,
	"compression": "maximum",
	"mac": {
		"target": [
			{
				"target": "dmg",
				"arch": ["universal"]
			},
			{
				"target": "zip",
				"arch": ["universal"]
			}
		],
		"icon": "assets/icon.icns",
		"category": "public.app-category.developer-tools",
		"darkModeSupport": true,
		"hardenedRuntime": true,
		"gatekeeperAssess": false,
		"entitlements": "assets/entitlements.mac.plist",
		"entitlementsInherit": "assets/entitlements.mac.plist",
		"minimumSystemVersion": "10.15",
		"notarize": false
	},
	"dmg": {
		"background": "assets/dmg-background.png",
		"icon": "assets/icon.icns",
		"iconSize": 80,
		"iconTextSize": 12,
		"contents": [
			{
				"x": 130,
				"y": 180,
				"type": "file"
			},
			{
				"x": 410,
				"y": 180,
				"type": "link",
				"path": "/Applications"
			}
		],
		"window": {
			"width": 540,
			"height": 380
		},
		"format": "ULFO",
		"title": "${productName}",
		"writeUpdateInfo": false
	},
	"win": {
		"target": [
			{
				"target": "nsis",
				"arch": ["x64", "arm64"]
			},
			{
				"target": "portable",
				"arch": ["x64"]
			}
		],
		"icon": "assets/icon.ico",
		"publisherName": "EvalOps"
	},
	"nsis": {
		"oneClick": false,
		"perMachine": false,
		"allowToChangeInstallationDirectory": true,
		"deleteAppDataOnUninstall": false,
		"installerIcon": "assets/icon.ico",
		"uninstallerIcon": "assets/icon.ico",
		"installerHeaderIcon": "assets/icon.ico",
		"createDesktopShortcut": true,
		"createStartMenuShortcut": true,
		"shortcutName": "Composer"
	},
	"linux": {
		"target": [
			{
				"target": "AppImage",
				"arch": ["x64", "arm64"]
			},
			{
				"target": "deb",
				"arch": ["x64", "arm64"]
			},
			{
				"target": "rpm",
				"arch": ["x64"]
			}
		],
		"icon": "assets/icon.png",
		"category": "Development",
		"synopsis": "AI-powered coding assistant",
		"description": "Composer is a premium AI coding assistant that helps you write, debug, and understand code.",
		"maintainer": "EvalOps <support@evalops.com>",
		"vendor": "EvalOps"
	},
	"appImage": {
		"artifactName": "${productName}-${version}-${arch}.${ext}"
	},
	"deb": {
		"depends": ["libnotify4", "libxtst6", "libnss3"],
		"artifactName": "${productName}-${version}-${arch}.${ext}"
	},
	"rpm": {
		"artifactName": "${productName}-${version}-${arch}.${ext}"
	},
	"publish": {
		"provider": "github",
		"owner": "evalops",
		"repo": "composer",
		"releaseType": "release"
	},
	"afterSign": "scripts/notarize.cjs"
}
