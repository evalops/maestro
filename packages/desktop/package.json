{
	"name": "@evalops/composer-desktop",
	"version": "0.10.0",
	"description": "Composer Desktop - Beautiful Electron app for AI-assisted development",
	"type": "module",
	"main": "dist-electron/main/index.js",
	"scripts": {
		"clean": "node ../../scripts/clean-paths.js dist dist-electron",
		"dev": "vite",
		"build": "vite build && electron-builder --config electron-builder.json",
		"build:vite": "vite build",
		"preview": "vite preview",
		"check": "tsc --noEmit",
		"package": "npm run build:vite && electron-builder --config electron-builder.json",
		"package:mac": "npm run build:vite && electron-builder --mac --config electron-builder.json",
		"package:win": "npm run build:vite && electron-builder --win --config electron-builder.json",
		"package:linux": "npm run build:vite && electron-builder --linux --config electron-builder.json"
	},
	"keywords": [
		"composer",
		"ai",
		"desktop",
		"electron",
		"llm",
		"coding-assistant"
	],
	"author": "EvalOps",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evalops/composer.git",
		"directory": "packages/desktop"
	},
	"dependencies": {
		"@evalops/contracts": "workspace:*",
		"electron-store": "^10.0.1",
		"electron-updater": "^6.3.9"
	},
	"devDependencies": {
		"@types/node": "^24.10.7",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"electron": "^33.2.1",
		"electron-builder": "^25.1.8",
		"highlight.js": "^11.10.0",
		"marked": "^17.0.0",
		"postcss": "^8.4.49",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.9.3",
		"vite": "^6.0.3",
		"vite-plugin-electron": "^0.28.8",
		"vite-plugin-electron-renderer": "^0.14.6"
	}
}
