{
	"name": "@evalops/contracts",
	"version": "0.10.0",
	"description": "Shared Composer contracts for frontend/backend integration",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": ["dist"],
	"scripts": {
		"clean": "node ../../scripts/clean-paths.js dist ../../tmp/tsbuildinfo/contracts.tsbuildinfo",
		"build": "node ../../scripts/clean-paths.js dist ../../tmp/tsbuildinfo/contracts.tsbuildinfo && node ../../scripts/ensure-dir.js ../../tmp/tsbuildinfo && tsc -p tsconfig.build.json",
		"dev": "node ../../scripts/ensure-dir.js ../../tmp/tsbuildinfo && tsc -p tsconfig.build.json --watch --preserveWatchOutput"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.0"
	},
	"keywords": ["composer", "contracts", "evalops"],
	"author": "EvalOps",
	"license": "MIT"
}
