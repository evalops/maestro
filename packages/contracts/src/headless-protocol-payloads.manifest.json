{
	"namedSchemas": {
		"HeadlessClientInfoSchema": {
			"kind": "object",
			"additionalProperties": false,
			"properties": {
				"name": { "kind": "string" },
				"version": { "kind": "string", "optional": true }
			}
		},
		"HeadlessClientCapabilitiesSchema": {
			"kind": "object",
			"additionalProperties": false,
			"properties": {
				"server_requests": {
					"kind": "array",
					"items": { "kind": "enumRef", "name": "headlessServerRequestTypes" },
					"uniqueItems": true,
					"optional": true
				},
				"utility_operations": {
					"kind": "array",
					"items": { "kind": "enumRef", "name": "headlessUtilityOperations" },
					"uniqueItems": true,
					"optional": true
				},
				"raw_agent_events": {
					"kind": "boolean",
					"optional": true
				}
			}
		},
		"HeadlessOptOutNotificationsSchema": {
			"kind": "array",
			"items": { "kind": "enumRef", "name": "headlessNotificationTypes" },
			"uniqueItems": true
		},
		"HeadlessToolResponseResultSchema": {
			"kind": "object",
			"additionalProperties": false,
			"properties": {
				"success": { "kind": "boolean" },
				"output": { "kind": "string" },
				"error": { "kind": "string", "optional": true }
			}
		},
		"HeadlessTextContentSchema": {
			"kind": "object",
			"additionalProperties": false,
			"properties": {
				"type": { "kind": "literal", "value": "text" },
				"text": { "kind": "string" }
			}
		},
		"HeadlessImageContentSchema": {
			"kind": "object",
			"additionalProperties": false,
			"properties": {
				"type": { "kind": "literal", "value": "image" },
				"data": { "kind": "string" },
				"mimeType": { "kind": "string" }
			}
		},
		"HeadlessContentBlockSchema": {
			"kind": "union",
			"variants": [
				{ "kind": "ref", "name": "HeadlessTextContentSchema" },
				{ "kind": "ref", "name": "HeadlessImageContentSchema" }
			]
		}
	},
