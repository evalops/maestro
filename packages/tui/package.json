{
	"name": "@evalops/tui",
	"version": "0.10.0",
	"description": "Terminal UI library with differential rendering for Composer",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"import": "./dist/testing/index.js"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"clean": "node ../../scripts/clean-paths.js dist ../../tmp/tsbuildinfo/tui.tsbuildinfo",
		"build": "node ../../scripts/clean-paths.js dist ../../tmp/tsbuildinfo/tui.tsbuildinfo && node ../../scripts/ensure-dir.js ../../tmp/tsbuildinfo && tsc -p tsconfig.build.json",
		"dev": "node ../../scripts/ensure-dir.js ../../tmp/tsbuildinfo && tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"check": "node ../../scripts/ensure-dir.js ../../tmp/tsbuildinfo && tsc -p tsconfig.build.json --noEmit",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli",
		"composer"
	],
	"author": "EvalOps",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evalops/composer.git",
		"directory": "packages/tui"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"chalk": "^5.5.0",
		"marked": "^17.0.0",
		"string-width": "^8.1.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@xterm/headless": "^5.5.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	}
}
