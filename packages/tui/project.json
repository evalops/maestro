{
	"name": "tui",
	"projectType": "library",
	"root": "packages/tui",
	"sourceRoot": "packages/tui/src",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/tui && bun run build",
				"forwardAllArgs": true
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/tui && bun run test",
				"forwardAllArgs": true
			}
		},
		"check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/tui && bun run check",
				"forwardAllArgs": true
			}
		}
	}
}
