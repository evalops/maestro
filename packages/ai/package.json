{
	"name": "@evalops/ai",
	"version": "0.10.0",
	"description": "Shared Composer AI SDK (models, transport, and agent event stream facade).",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md"],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"check": "tsc -p tsconfig.build.json --noEmit",
		"test": "vitest --run --passWithNoTests",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": ["ai", "llm", "agent", "streaming", "composer"],
	"author": "EvalOps",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evalops/composer.git",
		"directory": "packages/ai"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@evalops/contracts": "^0.10.0",
		"@google/genai": "^1.29.1",
		"@sinclair/typebox": "^0.33.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	}
}
