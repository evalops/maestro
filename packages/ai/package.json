			"default": "./dist/src/ide/index.js"
		},
		"./ide/*": {
			"types": "./dist/src/ide/*.d.ts",
			"default": "./dist/src/ide/*.js"
		},
		"./utils/*": {
			"types": "./dist/src/utils/*.d.ts",
			"default": "./dist/src/utils/*.js"
		},
		"./training": {
			"types": "./dist/src/training.d.ts",
			"default": "./dist/src/training.js"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"check": "tsc -p tsconfig.build.json --noEmit",
		"test": "vitest --run --passWithNoTests",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": ["ai", "llm", "agent", "streaming", "composer"],
	"author": "EvalOps",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evalops/composer.git",
		"directory": "packages/ai"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@evalops/contracts": "^0.10.0",
		"@google/genai": "^1.29.1",
		"@sinclair/typebox": "^0.33.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	}
}
