		},
		"./tools/background": {
			"types": "./dist/src/tools/background/index.d.ts",
			"default": "./dist/src/tools/background/index.js"
		},
		"./tools/background/*": {
			"types": "./dist/src/tools/background/*.d.ts",
			"default": "./dist/src/tools/background/*.js"
		},
		"./safety/*": {
			"types": "./dist/src/safety/*.d.ts",
			"default": "./dist/src/safety/*.js"
