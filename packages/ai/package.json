		},
		"./session/*": {
			"types": "./dist/src/session/*.d.ts",
			"default": "./dist/src/session/*.js"
		},
		"./runtime/background-settings": {
			"types": "./dist/src/runtime/background-settings.d.ts",
			"default": "./dist/src/runtime/background-settings.js"
		},
		"./telemetry": {
			"types": "./dist/src/telemetry/index.d.ts",
