{
	"name": "@evalops/ai",
	"version": "0.10.0",
	"description": "Shared Composer AI SDK (models, transport, and agent event stream facade).",
	"type": "module",
	"main": "./dist/packages/ai/src/index.js",
	"types": "./dist/packages/ai/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/packages/ai/src/index.d.ts",
			"default": "./dist/packages/ai/src/index.js"
		},
		"./agent": {
			"types": "./dist/src/agent/index.d.ts",
			"default": "./dist/src/agent/index.js"
		},
		"./agent/*": {
			"types": "./dist/src/agent/*.d.ts",
			"default": "./dist/src/agent/*.js"
		},
		"./transport": {
			"types": "./dist/src/agent/transport.d.ts",
			"default": "./dist/src/agent/transport.js"
		},
		"./types": {
			"types": "./dist/src/agent/types.d.ts",
			"default": "./dist/src/agent/types.js"
		},
		"./models": {
			"types": "./dist/src/models/builtin.d.ts",
			"default": "./dist/src/models/builtin.js"
		},
