			"types": "./dist/src/models/*.d.ts",
			"default": "./dist/src/models/*.js"
		},
		"./providers/*": {
			"types": "./dist/src/providers/*.d.ts",
			"default": "./dist/src/providers/*.js"
		},
		"./tools": {
			"types": "./dist/src/tools/index.d.ts",
