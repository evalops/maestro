			"default": "./dist/src/oauth/index.js"
		},
		"./oauth/*": {
			"types": "./dist/src/oauth/*.d.ts",
			"default": "./dist/src/oauth/*.js"
		},
		"./billing/*": {
			"types": "./dist/src/billing/*.d.ts",
			"default": "./dist/src/billing/*.js"
		},
		"./db/*": {
			"types": "./dist/src/db/*.d.ts",
			"default": "./dist/src/db/*.js"
		},
		"./enterprise/*": {
			"types": "./dist/src/enterprise/*.d.ts",
			"default": "./dist/src/enterprise/*.js"
