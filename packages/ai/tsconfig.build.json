{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "../../",
		"composite": true,
		"tsBuildInfoFile": "../../tmp/tsbuildinfo/ai.tsbuildinfo"
	},
	"include": [
		"src/**/*.ts",
		"../../src/agent/**/*.ts",
		"../../src/models/**/*.ts",
		"../../src/providers/**/*.ts",
		"../../src/tools/**/*.ts",
		"../../src/utils/**/*.ts",
		"../../src/hooks/**/*.ts",
		"../../src/theme/**/*.ts",
		"../../src/safety/**/*.ts",
		"../../src/tracking/**/*.ts",
		"../../src/config/constants.ts",
		"../../src/config/env-vars.ts",
		"../../src/config/firewall-config.ts",
		"../../src/config/framework.ts",
		"../../src/config/index.ts",
		"../../src/config/lsp-config.ts",
		"../../src/config/toml-config.ts",
		"../../src/oauth/**/*.ts",
		"../../src/sandbox/**/*.ts",
		"../../src/session/metadata-cache.ts",
		"../../src/session/types.ts",
		"../../src/runtime/background-settings.ts",
		"../../src/telemetry/**/*.ts",
		"../../src/telemetry.ts",
		"../../src/opentelemetry.ts",
		"../../src/training.ts",
		"../../src/guardian/**/*.ts",
		"../../src/lsp/**/*.ts",
		"../../src/ide/**/*.ts",
		"../../src/errors/**/*.ts",
		"../../src/workspace/**/*.ts"
	],
	"exclude": ["node_modules", "dist"],
	"references": [
		{ "path": "../contracts/tsconfig.build.json" },
		{ "path": "../tui/tsconfig.build.json" }
	]
}
