{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "../../",
		"composite": true,
		"tsBuildInfoFile": "../../tmp/tsbuildinfo/core.tsbuildinfo"
	},
	"include": [
		"src/**/*.ts",
		"../../src/agent/**/*.ts",
		"../../src/sandbox/**/*.ts",
		"../../src/tools/background/**/*.ts",
		"../../src/tools/tool-dsl.ts",
		"../../src/tools/image-processor.ts",
		"../../src/tools/shell-utils.ts",
		"../../src/tools/process-tree.ts",
		"../../src/tools/background-tasks.ts",
		"../../src/tools/todo.ts",
		"../../src/tools/parallel-execution.ts",
		"../../src/cli/args.ts",
		"../../src/theme/**/*.ts",
		"../../src/utils/**/*.ts",
		"../../src/config/**/*.ts",
		"../../src/providers/**/*.ts",
		"../../src/safety/**/*.ts",
		"../../src/hooks/**/*.ts",
		"../../src/tracking/**/*.ts",
		"../../src/models/**/*.ts",
		"../../src/telemetry/**/*.ts",
		"../../src/telemetry.ts",
		"../../src/opentelemetry.ts",
		"../../src/training.ts",
