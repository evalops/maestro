{
	"name": "composer-vscode",
	"displayName": "Composer",
	"description": "Use Composer's deterministic AI assistant inside VS Code.",
	"publisher": "evalops",
	"version": "0.10.0",
	"license": "MIT",
	"type": "commonjs",
	"main": "./dist/extension.js",
	"icon": "media/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/evalops/composer.git",
		"directory": "packages/vscode-extension"
	},
	"homepage": "https://github.com/evalops/composer#readme",
	"bugs": {
		"url": "https://github.com/evalops/composer/issues"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": ["Machine Learning", "Chat", "Programming Languages"],
	"activationEvents": [
		"onView:composer.chatView",
		"onCommand:composer.openPanel",
		"onCommand:composer.openDocs"
	],
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "composer-sidebar",
					"title": "Composer",
					"icon": "$(hubot)"
				}
			]
		},
		"views": {
			"composer-sidebar": [
				{
					"type": "webview",
					"id": "composer.chatView",
					"name": "Chat"
				}
			]
		},
		"commands": [
			{
				"command": "composer.openPanel",
				"title": "Composer: Open Assistant Panel",
				"category": "Composer"
			},
			{
				"command": "composer.openDocs",
				"title": "Composer: Open Documentation",
				"category": "Composer"
			},
			{
				"command": "composer.clearChat",
				"title": "Clear Chat",
				"category": "Composer",
				"icon": "$(clear-all)"
			},
			{
				"command": "composer.switchSession",
				"title": "Switch Session",
				"category": "Composer",
				"icon": "$(history)"
			},
			{
				"command": "composer.addToContext",
				"title": "Add File to Context",
				"category": "Composer",
				"icon": "$(pin)"
			},
			{
				"command": "composer.removeFromContext",
				"title": "Remove File from Context",
				"category": "Composer",
				"icon": "$(close)"
			},
			{
				"command": "composer.showCommandPicker",
				"title": "Run Command",
				"category": "Composer",
				"icon": "$(terminal)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "composer.showCommandPicker",
					"when": "view == composer.chatView",
					"group": "navigation@1"
				},
				{
					"command": "composer.switchSession",
					"when": "view == composer.chatView",
					"group": "navigation@2"
				},
				{
					"command": "composer.clearChat",
					"when": "view == composer.chatView",
					"group": "navigation@3"
				}
			],
			"editor/title/context": [
				{
					"command": "composer.addToContext",
					"group": "navigation"
				}
			]
		},

		"configuration": {
			"title": "Composer",
			"properties": {
				"composer.apiEndpoint": {
					"type": "string",
					"default": "http://localhost:8080",
					"description": "URL of the Composer API server"
				},
				"composer.model": {
					"type": "string",
					"default": "claude-sonnet-4-5",
					"description": "Model ID to use for chat generation"
				}
			}
		}
	},
	"scripts": {
		"clean": "node -e \"const fs=require('fs'); ['dist','out'].forEach(p=>fs.rmSync(p,{recursive:true,force:true})); for (const entry of fs.readdirSync('.')) if (entry.endsWith('.vsix')) fs.rmSync(entry,{force:true});\"",
		"build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
		"watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
		"prepackage": "bun run build",
		"package": "npx @vscode/vsce package --no-dependencies --out composer-$npm_package_version.vsix",
		"publish": "npx @vscode/vsce publish --no-dependencies",
		"check": "tsc --noEmit",
		"test": "vitest --run"
	},
	"dependencies": {
		"@evalops/contracts": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@types/vscode": "^1.90.0",
		"@vscode/test-electron": "^2.3.0",
		"@vscode/vsce": "^3.2.1",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	}
}
