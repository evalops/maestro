{
	"name": "vscode-extension",
	"projectType": "application",
	"root": "packages/vscode-extension",
	"sourceRoot": "packages/vscode-extension/src",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/vscode-extension && bun run build",
				"forwardAllArgs": true
			}
		},
		"check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/vscode-extension && bun run check",
				"forwardAllArgs": true
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/vscode-extension && bun run test",
				"forwardAllArgs": true
			}
		},
		"package": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/vscode-extension && bun run package",
				"forwardAllArgs": true
			}
		}
	}
}
