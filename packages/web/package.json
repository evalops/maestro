{
	"name": "@evalops/maestro-web",
	"version": "0.10.5",
	"description": "Web UI for Maestro - Browser-based AI coding assistant interface",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md"],
	"scripts": {
		"clean": "node ../../scripts/clean-paths.js dist",
		"build": "node ../../scripts/clean-paths.js dist && node ../../node_modules/vite/bin/vite.js build",
		"dev": "vite",
		"preview": "vite preview",
		"check": "tsc --noEmit",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": ["maestro", "ai", "web-ui", "llm", "coding-assistant", "browser"],
	"author": "EvalOps",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/evalops/maestro.git",
		"directory": "packages/web"
	},
	"dependencies": {
		"@evalops/contracts": "^0.10.5",
		"docx-preview": "^0.3.7",
		"dompurify": "^3.3.0",
		"highlight.js": "^11.10.0",
		"lit": "^3.2.1",
		"marked": "^17.0.0",
		"partial-json": "^0.1.7",
		"pdfjs-dist": "^5.4.449",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@open-wc/testing": "^4.0.0",
		"@types/node": "^24.10.7",
		"happy-dom": "^20.0.11",
		"typescript": "^5.9.3",
		"vite": "^6.0.3",
		"vitest": "^4.0.7"
	}
}
