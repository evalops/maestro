{
	"name": "composer-web",
	"projectType": "application",
	"root": "packages/web",
	"sourceRoot": "packages/web/src",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/web && bun run build",
				"forwardAllArgs": true
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/web && bun run test",
				"forwardAllArgs": true
			}
		},
		"check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/web && bun run check",
				"forwardAllArgs": true
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/web && bun run dev",
				"forwardAllArgs": true
			}
		}
	}
}
