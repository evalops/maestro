{
	"name": "jetbrains-plugin",
	"projectType": "application",
	"root": "packages/jetbrains-plugin",
	"sourceRoot": "packages/jetbrains-plugin/src",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/build/distributions/*.zip"],
			"options": {
				"command": "cd packages/jetbrains-plugin && ./gradlew buildPlugin",
				"forwardAllArgs": true
			}
		},
		"check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/jetbrains-plugin && ./gradlew check",
				"forwardAllArgs": true
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/jetbrains-plugin && ./gradlew test",
				"forwardAllArgs": true
			}
		},
		"runIde": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/jetbrains-plugin && ./gradlew runIde",
				"forwardAllArgs": true
			}
		},
		"verifyPlugin": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/jetbrains-plugin && ./gradlew verifyPlugin",
				"forwardAllArgs": true
			},
			"dependsOn": ["build"]
		},
		"publishPlugin": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/jetbrains-plugin && ./gradlew publishPlugin",
				"forwardAllArgs": true
			},
			"dependsOn": ["build", "verifyPlugin"]
		},
		"clean": {
			"executor": "nx:run-commands",
			"options": {
				"command": "cd packages/jetbrains-plugin && ./gradlew clean",
				"forwardAllArgs": true
			}
		}
	}
}
