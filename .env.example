# Anthropic (required for default model)
ANTHROPIC_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# Google Gemini (optional)
GEMINI_API_KEY=

# Groq (optional)
GROQ_API_KEY=

# OpenRouter (optional)
OPENROUTER_API_KEY=

# xAI / Grok (optional)
XAI_API_KEY=

# Exa web search (optional)
EXA_API_KEY=

# Docker services (used by make db-up / db-migrate)
# MAESTRO_REDIS_URL=redis://localhost:6379
# MAESTRO_DATABASE_URL=postgresql://localhost:5432/maestro?user=maestro&password=maestro

# Override default model/provider
# MAESTRO_MODEL=claude-opus-4-6
# MAESTRO_MODEL_PROVIDER=anthropic
