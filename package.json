{
  "name": "@evalops/composer",
  "description": "Composer by EvalOps - Deterministic coding agent with TUI/CLI and Web UI for AI-assisted development",
  "version": "0.10.0",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "composer": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node ./scripts/clean-paths.js dist ./tmp/tsbuildinfo/composer.tsbuildinfo",
    "prepare": "husky",
    "install:local": "node ./scripts/install-client.js",
    "prebuild": "node ./scripts/ensure-deps.js",
    "build": "node ./scripts/ensure-dir.js ./tmp/tsbuildinfo && tsc -b tsconfig.build.json --force && bun build ./src/cli.ts --target node --packages external --external tree-sitter --external tree-sitter-bash --outfile dist/cli.js && chmod +x dist/cli.js && node ./scripts/copy-themes.js",
    "start": "node --enable-source-maps dist/cli.js",
    "start:native": "COMPOSER_AGENT_SCRIPT=\"$(pwd)/dist/cli.js\" ./packages/tui-rs/target/release/composer-tui",
    "dev": "node ./scripts/ensure-dir.js ./tmp/tsbuildinfo && tsc -b tsconfig.build.json --watch --preserveWatchOutput",
    "dev:all": "concurrently --names \"cli,test\" --prefix-colors \"cyan,yellow\" \"npm run dev\" \"npm run test:watch\"",
    "test:watch": "vitest --watch",
    "test:fast": "VITEST_FAST=1 vitest --run",
    "lint": "biome check . && npm run lint:evals",
    "lint:evals": "node scripts/verify-evals.js && node scripts/verify-tool-versions.js && node scripts/validate-system-paths.js && node scripts/validate-package-boundaries.js",
    "format": "biome format .",
    "check": "npm run lint && npm run check --workspaces --if-present && tsc --noEmit",
    "evals": "npm run build && node scripts/run-evals.js",
    "telemetry:report": "node scripts/telemetry-report.js",
    "generate-models": "bun scripts/generate-models.ts",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "prepublishOnly": "npm run clean && npm run build",
    "bun:install": "bun install",
    "bun:cli": "bun run ./src/cli.ts",
    "bun:watch": "bun run --watch ./src/cli.ts",
    "web": "node dist/web-server.js",
    "web:dev": "concurrently --names \"server,ui\" --prefix-colors \"blue,green\" \"tsx --watch src/web-server.ts\" \"bun run dev:web\"",
    "bun:lint": "bunx biome check . && bun run lint:evals",
    "bun:test": "bunx vitest --run",
    "bun:test:fast": "VITEST_FAST=1 bunx vitest --run",
    "bun:check": "bun run bun:lint && bunx tsc --noEmit",
    "bun:compile": "npm run build && bun build ./dist/cli.js --compile --external tree-sitter --external tree-sitter-bash --outfile dist/composer-bun",
    "bun:compile:bytecode": "npm run build && bun build ./dist/cli.js --compile --bytecode --external tree-sitter --external tree-sitter-bash --outfile dist/composer-bun-bytecode",
    "bun:evals": "bun run build && bun run ./scripts/run-evals.js",
    "compile:binary": "npm run bun:compile && echo \"Binary ready at dist/composer-bun\"",
    "cli": "node ./dist/cli.js",
    "verify-build": "bun scripts/verify-build.ts",
    "verify-build:packages": "VERIFY_PACKAGES=1 bun scripts/verify-build.ts",
    "tui": "npm run cli",
    "verify": "npm run format && npm run lint && npm run test && npm run build && npm run smoke && npm run telemetry:report",
    "smoke": "node scripts/smoke-cli.js",
    "factory:import": "npm run build && node dist/scripts/import-factory-config.js",
    "factory:export": "npm run build && node dist/scripts/export-factory-config.js",
    "version:patch": "node scripts/version.js patch",
    "version:minor": "node scripts/version.js minor",
    "version:major": "node scripts/version.js major",
    "version:sync": "node scripts/sync-versions.js",
    "openapi:generate": "bun scripts/generate-openapi.ts",
    "openapi:serve": "bun scripts/serve-openapi.ts",
    "nix:update-hash": "bash scripts/update-nix-hash.sh",
    "dev:web": "bun run --filter @evalops/composer-web dev",
    "dev:tui": "bun run --filter @evalops/tui dev",
    "dev:packages": "concurrently --names \"tui,web\" --prefix-colors \"magenta,green\" \"bun run dev:tui\" \"bun run dev:web\"",
    "guardian": "bash scripts/guardian.sh",
    "guardian:install-hook": "node scripts/install-guardian-hook.js",
    "build:all": "bun run --filter @evalops/contracts build && bun run --filter @evalops/tui build && bun run --filter @evalops/composer-web build && bun run build && bun run --filter @evalops/ai build",
    "test:all": "npm run test && npm run test --workspaces --if-present",
    "db:generate": "COMPOSER_DATABASE_TYPE=postgres drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:migrate:status": "bun run -e \"import('./src/db/migrate.js').then(m => m.getMigrationStatus()).then(console.log)\"",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:check": "bun run src/db/check.ts",
    "vscode:build": "npx nx run vscode-extension:build",
    "vscode:package": "npx nx run vscode-extension:package",
    "vscode:publish": "npx nx run vscode-extension:publish",
    "tui-rs:build": "cd packages/tui-rs && cargo build --release",
    "tui-rs:build:debug": "cd packages/tui-rs && cargo build",
    "tui-rs:check": "cd packages/tui-rs && cargo check",
    "tui-rs:test": "cd packages/tui-rs && cargo test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.966.0",
    "@crosscopy/clipboard": "^0.2.8",
    "@evalops/contracts": "workspace:*",
    "@evalops/tui": "workspace:*",
    "@google/genai": "^1.35.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.2",
    "@opentelemetry/sdk-node": "0.209.0",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "@sinclair/typebox": "^0.34.47",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.0",
    "chalk": "^5.5.0",
    "clipboardy": "^4.0.0",
    "diff": "^8.0.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "0.45.1",
    "fflate": "^0.8.2",
    "glob": "^11.1.0",
    "ioredis": "^5.9.1",
    "jiti": "^2.6.1",
    "jose": "^6.1.3",
    "js-yaml": "^4.1.1",
    "jsonc-parser": "^3.3.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "marked": "^17.0.0",
    "mime-types": "^3.0.1",
    "minimatch": "^10.1.1",
    "openai": "^6.16.0",
    "otplib": "^12.0.1",
    "partial-json": "^0.1.7",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.8",
    "smol-toml": "^1.5.2",
    "string-width": "^8.1.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-bash": "^0.25.0",
    "uuid": "^13.0.0",
    "vscode-jsonrpc": "^8.2.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.5",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.3",
    "@nrwl/tao": "19.8.4",
    "@opentelemetry/resources": "^2.3.0",
    "@smithy/types": "^4.9.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.7",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.7",
    "esbuild": "^0.27.0",
    "fast-check": "^4.3.0",
    "husky": "^9.1.7",
    "luxon": "^3.7.2",
    "nx": "19.7.3",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "composer",
    "evalops",
    "ai",
    "llm",
    "cli",
    "tui",
    "agent"
  ],
  "author": "EvalOps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evalops/composer.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "optionalDependencies": {
    "sharp": "0.34.5"
  },
  "packageManager": "bun@1.1.31",
  "trustedDependencies": [
    "tree-sitter-bash"
  ]
}
