[
	{
		"name": "cli help renders",
		"args": ["--help"],
		"expectedRegex": "Composer v\\d+\\.\\d+\\.\\d+ by EvalOps"
	},
	{
		"name": "cli help json mode",
		"args": ["--help", "--mode", "json"],
		"expectedRegex": "Composer v\\d+\\.\\d+\\.\\d+ by EvalOps"
	},
	{
		"name": "read tool returns first line",
		"command": ["node", "scripts/run-read-tool.js", "README.md"],
		"expectedRegex": "Composer CLI by EvalOps"
	},
	{
		"name": "cli help lists env vars",
		"args": ["--help"],
		"expectedRegex": "Environment Variables:\\s+GEMINI_API_KEY"
	},
	{
		"name": "telemetry report summarizes log",
		"command": [
			"node",
			"scripts/telemetry-report.js",
			"evals/sample-telemetry.log"
		],
		"expectedRegex": "Telemetry Summary\\n=+\\nLog file: .*sample-telemetry\\.log",
		"expectedStdoutRegex": "Tool success rate: 50\\.0%"
	},
	{
		"name": "telemetry report missing log fails",
		"command": [
			"node",
			"scripts/telemetry-report.js",
			"evals/does-not-exist.log"
		],
		"expectedExitCode": 1,
		"expectedStderrRegex": "Telemetry log not found"
	}
]
