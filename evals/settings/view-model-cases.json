		"expected": {
			"approvalMode": "prompt",
			"guardianChecked": true,
			"guardianEnabledLabel": "On",
			"guardianActionLabel": "Running…",
			"guardianActionDisabled": true,
			"lastRun": {
				"status": "passed",
				"summary": "No secrets found",
				"durationLabel": "1.5s",
				"timestampLabel": "Unknown"
			}
		}
	},
	{
		"name": "safety approvals preserve fallback behavior without guardian status",
		"kind": "safetyApprovals",
		"input": {
			"approvalMode": "auto",
			"guardianStatus": null,
			"guardianRunning": false
		},
		"expected": {
			"approvalMode": "auto",
			"guardianChecked": true,
			"guardianEnabledLabel": "Off",
			"guardianActionLabel": "Run now",
			"guardianActionDisabled": false,
			"lastRun": null
		}
	},
	{
