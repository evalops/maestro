			"showSessionWarning": true,
			"zenModeLabel": "Off",
			"cleanMode": "soft",
			"footerMode": "solo",
			"compactToolsLabel": "On"
		}
	},
	{
		"name": "terminal ui enables controls for active sessions",
		"kind": "terminalUi",
		"input": {
			"uiStatus": {
				"zenMode": true,
				"cleanMode": "aggressive",
				"footerMode": "ensemble",
				"compactTools": false,
				"queueMode": "one"
			},
			"hasSession": true
		},
		"expected": {
			"controlsDisabled": false,
			"showSessionWarning": false,
			"zenModeLabel": "On",
			"cleanMode": "aggressive",
			"footerMode": "ensemble",
			"compactToolsLabel": "Off"
		}
	},
	{
		"name": "safety approvals summarize an in-flight guardian run",
		"kind": "safetyApprovals",
		"input": {
			"approvalMode": "prompt",
			"guardianStatus": {
				"enabled": true,
				"state": {
					"enabled": true,
