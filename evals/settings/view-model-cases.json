[
	{
		"name": "appearance shows the enabled dark comfortable state",
		"kind": "appearance",
		"input": {
			"themeMode": "dark",
			"showTimestamps": true,
			"density": "comfortable"
		},
		"expected": {
			"themeMode": "dark",
			"showTimestampsLabel": "On",
			"isComfortableSelected": true,
			"isCompactSelected": false
		}
	},
	{
		"name": "appearance shows the disabled compact state",
		"kind": "appearance",
		"input": {
			"themeMode": "system",
			"showTimestamps": false,
			"density": "compact"
		},
		"expected": {
			"themeMode": "system",
			"showTimestampsLabel": "Off",
			"isComfortableSelected": false,
			"isCompactSelected": true
		}
	},
	{
		"name": "session behavior disables queue mode without an active session",
		"kind": "sessionBehavior",
		"input": {
			"hasSession": false,
			"queueMode": "all"
		},
		"expected": {
			"queueMode": "all",
			"queueModeDisabled": true,
			"showSessionWarning": true
		}
	},
	{
		"name": "session behavior enables queue mode when a session exists",
		"kind": "sessionBehavior",
		"input": {
			"hasSession": true,
			"queueMode": "one"
		},
		"expected": {
			"queueMode": "one",
			"queueModeDisabled": false,
			"showSessionWarning": false
		}
	},
	{
		"name": "background tasks default to off and zero counts when status is missing",
		"kind": "backgroundTasks",
		"input": {
			"status": null
		},
		"expected": {
			"notificationsEnabledLabel": "Off",
			"statusDetailsEnabledLabel": "Off",
			"runningCount": 0,
			"failedCount": 0,
			"totalCount": 0
		}
	},
	{
		"name": "background tasks summarize counts and labels",
		"kind": "backgroundTasks",
		"input": {
			"status": {
				"settings": {
					"notificationsEnabled": true,
					"statusDetailsEnabled": false
				},
				"snapshot": {
					"running": 2,
					"failed": 1,
					"total": 5
				}
			}
		},
		"expected": {
			"notificationsEnabledLabel": "On",
			"statusDetailsEnabledLabel": "Off",
			"runningCount": 2,
			"failedCount": 1,
			"totalCount": 5
		}
	},
	{
		"name": "framework options prepend none and preserve workspace scope",
		"kind": "framework",
		"input": {
			"frameworks": [
				{ "id": "react", "summary": "React" },
				{ "id": "nextjs", "summary": "Next.js" }
			],
			"frameworkId": "nextjs",
			"frameworkScope": "workspace",
			"frameworkLocked": false
		},
		"expected": {
			"options": [
				{ "id": "none", "label": "None" },
				{ "id": "react", "label": "react" },
				{ "id": "nextjs", "label": "nextjs" }
			],
			"selectedFrameworkId": "nextjs",
			"isUserScopeSelected": false,
			"isWorkspaceScopeSelected": true,
			"isLocked": false,
			"lockedMessage": null
		}
	},
	{
		"name": "framework lock surfaces the policy warning",
		"kind": "framework",
		"input": {
			"frameworks": [{ "id": "vue", "summary": "Vue" }],
			"frameworkId": "vue",
			"frameworkScope": "user",
			"frameworkLocked": true
		},
		"expected": {
			"selectedFrameworkId": "vue",
			"isUserScopeSelected": true,
			"isWorkspaceScopeSelected": false,
			"isLocked": true,
			"lockedMessage": "Framework is locked by policy."
		}
	},
	{
		"name": "model reasoning dedupes available models and keeps mode details",
		"kind": "modelReasoning",
		"input": {
			"availableModels": [
				{ "id": "sonnet", "name": "Claude Sonnet", "provider": "anthropic" },
				{ "id": "sonnet", "name": "Claude Sonnet", "provider": "anthropic" },
				{ "id": "gpt-5", "provider": "openai" }
			],
			"fallbackModels": [{ "id": "fallback", "provider": "openai" }],
			"selectedModelId": "anthropic:sonnet",
			"modeStatus": {
				"mode": "rush",
				"config": { "description": "Fastest response path" }
			},
			"modeOptions": ["smart", "rush"],
			"thinkingLevel": "high"
		},
		"expected": {
			"modelOptions": [
				{ "id": "anthropic:sonnet", "label": "Claude Sonnet · anthropic" },
				{ "id": "openai:gpt-5", "label": "gpt-5 · openai" }
			],
			"modelEmptyLabel": null,
			"selectedModelId": "anthropic:sonnet",
			"selectedMode": "rush",
			"modeDescription": "Fastest response path",
			"thinkingLevel": "high"
		}
	},
	{
		"name": "model reasoning falls back to fallback models and default modes",
		"kind": "modelReasoning",
		"input": {
			"availableModels": [],
			"fallbackModels": [{ "id": "sonnet", "provider": "anthropic" }],
			"selectedModelId": "anthropic:sonnet",
			"modeStatus": null,
			"modeOptions": [],
			"thinkingLevel": "minimal"
		},
		"expected": {
			"modelOptions": [
				{ "id": "anthropic:sonnet", "label": "sonnet · anthropic" }
			],
			"modeOptions": ["smart", "rush", "free", "custom"],
			"selectedMode": "smart",
			"modeDescription": null,
			"thinkingLevel": "minimal"
		}
	},
	{
		"name": "mode option normalization dedupes mixed entries",
		"kind": "modeOptions",
		"input": {
			"modes": [
				"smart",
				{ "mode": "rush", "config": { "description": "Fast" } },
				"smart",
				{ "mode": "custom", "config": {} }
			]
		},
		"expected": ["smart", "rush", "custom"]
	},
	{
		"name": "mode option normalization falls back to defaults when empty",
		"kind": "modeOptions",
		"input": {
			"modes": []
		},
		"expected": ["smart", "rush", "free", "custom"]
	},
	{
		"name": "planning describes an inactive plan mode",
		"kind": "planning",
		"input": {
			"status": null,
			"planDirty": false
		},
		"expected": {
			"isActive": false,
			"actionLabel": "Start plan",
			"showNameInput": true,
			"showEditor": false,
			"planFileLabel": "Plan file not created yet",
			"saveDisabled": true
		}
	},
	{
		"name": "planning enables saving for an active dirty plan",
		"kind": "planning",
		"input": {
			"status": {
				"state": {
					"active": true,
					"filePath": "/tmp/plan.md"
				},
				"content": "- [ ] write tests"
			},
			"planDirty": true
		},
		"expected": {
			"isActive": true,
			"actionLabel": "Exit plan",
			"showNameInput": false,
			"showEditor": true,
			"planFileLabel": "/tmp/plan.md",
			"saveDisabled": false
		}
	},
	{
		"name": "terminal ui disables controls without a session",
		"kind": "terminalUi",
		"input": {
			"uiStatus": {
				"zenMode": false,
				"cleanMode": "soft",
				"footerMode": "solo",
				"compactTools": true,
				"queueMode": "all"
			},
