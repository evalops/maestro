{
	"name": "composer",
	"projectType": "application",
	"root": ".",
	"sourceRoot": "src",
	"implicitDependencies": ["composer-web", "tui", "@evalops/ai", "contracts"],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun run build",
				"forwardAllArgs": true
			}
		},
		"build:all": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun run build:all",
				"forwardAllArgs": true
			}
		},
		"verify-build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun run verify-build",
				"forwardAllArgs": true
			}
		},
		"smoke": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun run smoke",
				"forwardAllArgs": true
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun run bun:lint",
				"forwardAllArgs": true
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"dependsOn": ["build"],
			"options": {
				"command": "bun run bun:test",
				"forwardAllArgs": true
			}
		},
		"evals": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun run bun:evals",
				"forwardAllArgs": true
			}
		}
	}
}
