{
    "extends": "./tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"composite": true,
		"tsBuildInfoFile": "./tmp/tsbuildinfo/composer.tsbuildinfo"
	},
	"include": ["src/**/*.ts", "types/**/*.d.ts"],
	"exclude": ["node_modules", "dist"],
	"references": [
		{ "path": "./packages/tui/tsconfig.build.json" },
		{ "path": "./packages/contracts/tsconfig.build.json" }
	]
}
